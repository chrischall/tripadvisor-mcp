{
  "name": "@chrischall/tripadvisor-mcp",
  "version": "0.0.0",
  "mcpName": "io.github.chrischall/tripadvisor-mcp",
  "description": "TripAdvisor Content API MCP server for Claude \u2014 search locations, details, photos, and reviews. Developed and maintained by AI (Claude Code).",
  "author": "Claude Code (AI) <https://www.anthropic.com/claude>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chrischall/tripadvisor-mcp.git"
  },
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "ai",
    "tripadvisor",
    "travel",
    "hotels",
    "restaurants",
    "attractions",
    "reviews"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "tripadvisor-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    ".claude-plugin",
    "SKILL.md",
    ".mcp.json",
    "server.json"
  ],
  "scripts": {
    "build": "tsc && npm run bundle",
    "bundle": "esbuild src/index.ts --bundle --platform=node --format=esm --external:dotenv --banner:js='import { createRequire as __createRequire } from \"module\"; const require = __createRequire(import.meta.url);' --outfile=dist/bundle.js",
    "dev": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@chrischall/mcp-utils": "^0.10.0",
    "@fetchproxy/server": "^1.3.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
